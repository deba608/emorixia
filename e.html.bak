<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>💖 Emorixia - Handmade Memory Gifts & Personalized Keepsakes</title>

<!-- SEO Meta Tags -->
<meta name="description" content="Emorixia transforms memories into premium handcrafted gifts. Custom memory magazines, photo frames, Lippan art, resin art, and emotional keepsakes. 100+ orders delivered with love.">
<meta name="keywords" content="memory gifts, handmade keepsakes, personalized magazines, photo frames, memory art, Lippan art, resin art, emotional gifts, Odisha">
<meta name="author" content="Emorixia">
<meta name="robots" content="index, follow">

<!-- Open Graph / Social Media -->
<meta property="og:type" content="website">
<meta property="og:title" content="💖 Emorixia - Memories Forever">
<meta property="og:description" content="Transform your emotions into premium handcrafted memory gifts. Custom magazines, frames, and keepsakes made with love.">
<meta property="og:url" content="https://emorixia.in">
<meta property="og:image" content="https://emorixia.in/og-image.jpg">
<meta property="og:site_name" content="Emorixia">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="💖 Emorixia - Memories Forever">
<meta name="twitter:description" content="Premium handmade memory gifts and personalized keepsakes crafted with emotion.">
<meta name="twitter:image" content="https://emorixia.in/og-image.jpg">

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-YOUR_TRACKING_ID"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  // Replace 'G-YOUR_TRACKING_ID' with your actual Google Analytics ID
  gtag('config', 'G-YOUR_TRACKING_ID');
</script>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Amatic+SC:wght@400;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:'Poppins',sans-serif;
    background:#796a70;
    color:#11202b;
    overflow-x:hidden;
    padding-top:76px;
}

.site-header{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    z-index:20;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:16px;
    padding:18px 6%;
    backdrop-filter:blur(16px);
    background:rgba(12,12,12,0.28);
    border-bottom:1px solid rgba(255,255,255,0.1);
}

.site-logo{
    font-family:'Amatic SC', cursive;
    font-size:32px;
    color:#fff;
    letter-spacing:1px;
}

.site-nav{
    display:flex;
    flex-wrap:wrap;
    justify-content:flex-end;
    gap:22px;
}

.site-nav a{
    color:rgba(255,255,255,0.85);
    text-decoration:none;
    font-weight:600;
    transition:color 0.3s ease;
}

.site-nav a:hover{
    color:#ff8ba7;
}

/* HAMBURGER MENU */

.hamburger{
    display:none;
    flex-direction:column;
    cursor:pointer;
    gap:6px;
}

.hamburger span{
    width:28px;
    height:3px;
    background:#fff;
    border-radius:2px;
    transition:0.3s ease;
}

.hamburger.active span:nth-child(1){
    transform:rotate(45deg) translate(10px, 10px);
}

.hamburger.active span:nth-child(2){
    opacity:0;
}

.hamburger.active span:nth-child(3){
    transform:rotate(-45deg) translate(7px, -7px);
}

/* MOBILE NAV */

.site-nav.mobile-active{
    display:flex !important;
}

/* HERO */

.hero{
    position:relative;
    min-height:calc(100vh - 76px);
    overflow:hidden;

    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;

    color:rgb(237, 240, 242);
    padding:20px;
}

/* ABOUT SECTION */

.about-section{
    background:linear-gradient(180deg, #fff6fb 0%, #ffeaf2 100%);
    border:1px solid rgba(255,120,155,0.18);
    border-radius:30px;
    padding:70px 40px;
    box-shadow:0 18px 50px rgba(255,75,125,0.1);
}

.about-content{
    max-width:900px;
    margin:0 auto;
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:40px;
    align-items:center;
}

.about-text h3{
    color:#ff4b7d;
    font-size:28px;
    margin-bottom:16px;
}

.about-text p{
    color:#333;
    line-height:2;
    font-size:16px;
    margin-bottom:16px;
}

.about-stats{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:20px;
    margin-top:30px;
}

.stat-box{
    background:white;
    padding:24px;
    border-radius:16px;
    text-align:center;
    box-shadow:0 8px 20px rgba(255,75,125,0.08);
}

.stat-box .number{
    font-size:32px;
    font-weight:700;
    color:#ff4b7d;
}

.stat-box .label{
    font-size:14px;
    color:#666;
    margin-top:8px;
}

.about-features{
    display:flex;
    flex-direction:column;
    gap:16px;
}

.feature-item{
    display:flex;
    align-items:center;
    gap:12px;
    padding:12px;
    background:white;
    border-radius:12px;
    box-shadow:0 4px 12px rgba(255,75,125,0.06);
}

.feature-icon{
    font-size:24px;
}

.feature-text{
    color:#333;
    font-weight:500;
}

@media(max-width:768px){
    .about-content{
        grid-template-columns:1fr;
        gap:30px;
    }
    
    .about-section{
        padding:40px 24px;
    }
    
    .about-text h3{
        font-size:24px;
    }
}

/* HERO */

.hero video{
    position:absolute;
    top:0;
    left:0;
    width:100%;
    height:100%;
    display:block;
    object-fit:cover;
    object-position:center center;
    z-index:-3;
}

.hero::before{
    content:'';
    position:absolute;
    inset:0;
    background:linear-gradient(rgba(0,0,0,0.62),rgba(0,0,0,0.62));
    z-index:-2;
}

.hero::after{
    content:'';
    position:absolute;
    inset:0;
    background-image:
        radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 100px 100px, 140px 140px;
    opacity:0.35;
    z-index:-1;
    pointer-events:none;
}

.hero-content{
    animation:fadeUp 1.2s ease both;
    position:relative;
    z-index:1;
    width:min(100%,980px);
    background:rgba(255,255,255,0.16);
    backdrop-filter:blur(14px);
    border:1px dashed rgba(255,255,255,0.55);
    box-shadow:0 30px 80px rgba(0,0,0,0.28);
    padding:50px 45px;
    border-radius:38px;
}

.hero h1{
    font-family:'Amatic SC', cursive;
    font-size:78px;
    margin-bottom:18px;
    letter-spacing:1px;
}

.hero p{
    font-size:24px;
    max-width:750px;
    margin:auto;
    line-height:1.8;
}

.hero-buttons{
    margin-top:35px;
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:14px;
}

.hero-badge{
    margin-top:18px;
    display:inline-flex;
    align-items:center;
    gap:10px;
    padding:10px 18px;
    border-radius:999px;
    background:rgba(255,255,255,0.12);
    border:1px solid rgba(255,255,255,0.2);
    color:#fff;
    font-size:15px;
    letter-spacing:0.01em;
}

.hero-badge span{
    font-weight:700;
    color:#ffd4e5;
}

.paper-feature{
    margin-top:12px;
    display:inline-block;
    padding:8px 14px;
    background:rgba(255,255,255,0.06);
    color:#ffeef6;
    border-radius:12px;
    font-size:14px;
    border:1px solid rgba(255,255,255,0.06);
}

.paper-feature .odisha{
    color:#ff9933;
    font-weight:800;
    margin-right:8px;
    text-transform:capitalize;
}

.btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-width:180px;
    padding:14px 34px;
    margin:0;
    border-radius:40px;
    text-decoration:none;
    font-weight:600;
    letter-spacing:0.02em;
    transition:transform 0.3s ease, background 0.3s ease, color 0.3s ease;
    box-shadow:0 18px 40px rgba(0,0,0,0.12);
}

.btn-main{
    background:#ff4b7d;
    color:white;
}

.btn-main:hover{
    background:#ffffff;
    color:#111;
    transform:translateY(-4px);
}

.btn-outline{
    border:2px solid rgba(255,255,255,0.9);
    color:white;
    background:rgba(255,255,255,0.08);
}

.btn-outline:hover{
    background:white;
    color:#111;
    transform:translateY(-4px);
}

/* SECTION */

section{
    padding:90px 8%;
    position:relative;
}

.section-title{
    position:relative;
}

.section-title::after{
    content:'';
    display:block;
    width:72px;
    height:4px;
    margin:18px auto 0;
    background:#ff4b7d;
    border-radius:999px;
}

.section-title{
    text-align:center;
    font-size:42px;
    margin-bottom:55px;
    color:#ff4b7d;
}

/* CARDS */

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:30px;
}

.card{
    background:linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,244,250,0.98) 100%);
    border:1px solid rgba(255,255,255,0.8);
    border-radius:28px;
    overflow:hidden;
    box-shadow:0 22px 55px rgba(0,0,0,0.12);
    transition:transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
    animation:floatCard 5s ease-in-out infinite;
}

.card:hover{
    transform:translateY(-14px) scale(1.02);
    box-shadow:0 25px 65px rgba(255,75,125,0.22);
    border-color:rgba(255,75,125,0.3);
}

.card img{
    width:100%;
    height:400px;
    object-fit:cover;
    cursor:pointer;
    border-bottom:1px solid rgba(255,255,255,0.7);
}

.card-content{
    padding:26px 24px 30px;
}

.card-content h3{
    color:#ff4b7d;
    margin-bottom:10px;
    font-size:24px;
}

.card-content p{
    line-height:1.8;
}

/* GALLERY */

.gallery{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.gallery img{
    width:100%;
    height:400px;
    object-fit:cover;
    border-radius:20px;
    cursor:pointer;
    transition:0.4s;
}

.gallery img:hover{
    transform:scale(1.06);
    box-shadow:0 10px 30px rgba(0,0,0,0.3);
}

.feedback-section{
    background:linear-gradient(180deg, #fff8fb 0%, #fff1f7 100%);
    border:1px solid rgba(255,75,125,0.16);
    border-radius:30px;
    padding:60px 40px;
    box-shadow:0 20px 50px rgba(255,75,125,0.1);
    margin:60px 0;
}

.feedback-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:24px;
}

.feedback-card{
    background:rgba(255,255,255,0.95);
    border:1px solid rgba(255,75,125,0.12);
    border-radius:24px;
    padding:28px;
    min-height:220px;
    display:flex;
    flex-direction:column;
    justify-content:space-between;
    box-shadow:0 12px 30px rgba(0,0,0,0.08);
}

.feedback-card p{
    line-height:1.75;
    color:#4a4a4f;
    margin-bottom:18px;
}

.feedback-rating{
    display:flex;
    align-items:center;
    gap:8px;
    margin-bottom:16px;
}

.feedback-rating span{
    font-size:18px;
    color:#ff5a8f;
    letter-spacing:1px;
}

.feedback-rating small{
    color:#7a7a84;
    font-size:14px;
}

.feedback-author{
    display:flex;
    flex-direction:column;
    gap:4px;
    font-weight:700;
    color:#111;
}

.feedback-author span{
    font-size:14px;
    color:#7a7a84;
}

/* WHY */

.texture-info{
    margin-top:22px;
    background:rgba(255,255,255,0.02);
    padding:18px 20px;
    border-radius:12px;
    border:1px dashed rgba(255,75,125,0.06);
    color:#fffafa;
    max-width:900px;
    margin-left:auto;
    margin-right:auto;
}

.why{
    background:linear-gradient(180deg, #fff6fb 0%, #ffeaf2 100%);
    border:1px solid rgba(255,120,155,0.18);
    border-radius:30px;
    padding:70px 40px;
    text-align:center;
    box-shadow:0 18px 50px rgba(255,75,125,0.1);
}

.why p{
    max-width:850px;
    margin:auto;
    line-height:2;
    font-size:20px;
}

/* CONTACT */

.contact-box{
    background:linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(255,239,247,0.96) 100%);
    border:1px solid rgba(255,75,125,0.16);
    border-radius:30px;
    padding:52px 42px;
    box-shadow:0 22px 60px rgba(255,75,125,0.12);
    text-align:center;
}

.contact-buttons{
    margin-top:30px;
}

/* CONTACT FORM */

.contact-form{
    max-width:600px;
    margin:30px auto 0;
}

.form-group{
    margin-bottom:20px;
    display:flex;
    flex-direction:column;
}

.form-group label{
    font-weight:600;
    margin-bottom:8px;
    color:#ff4b7d;
    font-size:15px;
}

.form-group input,
.form-group textarea{
    padding:14px 16px;
    border:1px solid rgba(255,75,125,0.2);
    border-radius:12px;
    font-family:'Poppins', sans-serif;
    font-size:15px;
    resize:none;
    transition:0.3s ease;
}

.form-group input:focus,
.form-group textarea:focus{
    outline:none;
    border-color:#ff4b7d;
    box-shadow:0 0 0 3px rgba(255,75,125,0.1);
}

.form-group textarea{
    min-height:120px;
}

.submit-btn{
    width:100%;
    padding:16px;
    background:#ff4b7d;
    color:white;
    border:none;
    border-radius:12px;
    font-weight:600;
    font-size:16px;
    cursor:pointer;
    transition:0.3s ease;
}

.submit-btn:hover{
    background:#ff2d63;
    transform:translateY(-2px);
}

.form-message{
    text-align:center;
    margin-top:16px;
    padding:12px;
    border-radius:8px;
    font-size:14px;
    display:none;
}

.form-message.success{
    background:rgba(76,175,80,0.1);
    color:#4caf50;
    border:1px solid rgba(76,175,80,0.3);
    display:block;
}

.form-message.error{
    background:rgba(244,67,54,0.1);
    color:#f44336;
    border:1px solid rgba(244,67,54,0.3);
    display:block;
}

/* FOOTER */

footer{
    background:#111;
    color:white;
    text-align:center;
    padding:35px 20px;
}

footer a{
    color:#ff4b7d;
    text-decoration:none;
}

/* FAQ SECTION */

.faq-container{
    max-width:800px;
    margin:0 auto;
    background:linear-gradient(180deg, #fff8fb 0%, #fff1f7 100%);
    border:1px solid rgba(255,75,125,0.16);
    border-radius:30px;
    padding:60px 40px;
    box-shadow:0 20px 50px rgba(255,75,125,0.1);
}

.faq-item{
    margin-bottom:20px;
    border:1px solid rgba(255,75,125,0.1);
    border-radius:16px;
    overflow:hidden;
    background:white;
    transition:0.3s ease;
}

.faq-item:hover{
    box-shadow:0 8px 20px rgba(255,75,125,0.12);
    border-color:rgba(255,75,125,0.2);
}

.faq-question{
    padding:20px;
    background:rgba(255,75,125,0.04);
    cursor:pointer;
    display:flex;
    justify-content:space-between;
    align-items:center;
    font-weight:600;
    color:#ff4b7d;
    user-select:none;
    transition:0.3s ease;
}

.faq-question:hover{
    background:rgba(255,75,125,0.08);
}

.faq-icon{
    font-size:24px;
    transition:transform 0.3s ease;
}

.faq-item.active .faq-icon{
    transform:rotate(180deg);
}

.faq-answer{
    max-height:0;
    overflow:hidden;
    transition:max-height 0.3s ease;
    padding:0 20px;
    color:#666;
    line-height:1.8;
}

.faq-item.active .faq-answer{
    max-height:300px;
    padding:20px;
}

/* NEWSLETTER */

.newsletter-section{
    background:linear-gradient(135deg, #ff4b7d 0%, #ff8ba7 100%);
    color:white;
    text-align:center;
    padding:60px 40px;
    border-radius:30px;
    margin:60px 0;
}

.newsletter-section h2{
    font-size:32px;
    margin-bottom:16px;
    color:white;
}

.newsletter-section p{
    font-size:18px;
    margin-bottom:30px;
    opacity:0.95;
}

.newsletter-form{
    display:flex;
    max-width:500px;
    margin:0 auto;
    gap:12px;
    flex-wrap:wrap;
    justify-content:center;
}

.newsletter-form input{
    flex:1;
    min-width:250px;
    padding:14px 16px;
    border:none;
    border-radius:25px;
    font-size:15px;
    font-family:'Poppins', sans-serif;
    transition:0.3s ease;
}

.newsletter-form input:focus{
    outline:none;
    box-shadow:0 0 0 3px rgba(255,255,255,0.3);
}

.newsletter-form button{
    padding:14px 28px;
    background:white;
    color:#ff4b7d;
    border:none;
    border-radius:25px;
    font-weight:600;
    cursor:pointer;
    transition:0.3s ease;
}

.newsletter-form button:hover{
    transform:translateY(-2px);
    box-shadow:0 8px 20px rgba(0,0,0,0.2);
}

.newsletter-message{
    text-align:center;
    margin-top:16px;
    font-size:14px;
    display:none;
}

.newsletter-message.show{
    display:block;
}

/* IMAGE POPUP */

.image-popup{
    display:none;
    position:fixed;
    z-index:9999;
    left:0;
    top:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.9);

    justify-content:center;
    align-items:center;
    flex-direction:column;

    padding:20px;
}

.image-popup img{
    max-width:90%;
    max-height:80%;
    border-radius:20px;
    transition:transform 0.2s ease;
    cursor:grab;
}

/* CLOSE BUTTON */

.image-popup span{
    position:absolute;
    top:20px;
    right:35px;
    color:white;
    font-size:45px;
    cursor:pointer;
}

/* ZOOM BUTTONS */

.zoom-controls{
    position:absolute;
    bottom:40px;
    display:flex;
    gap:15px;
}

.zoom-controls button{
    padding:12px 20px;
    border:none;
    border-radius:12px;
    background:#ff4b7d;
    color:white;
    font-size:18px;
    cursor:pointer;
    transition:0.3s;
}

.zoom-controls button:hover{
    background:white;
    color:#111;
}

/* ANIMATION */

@keyframes fadeUp{
    from{
        transform:translateY(40px);
        opacity:0;
    }

    to{
        transform:translateY(0);
        opacity:1;
    }
}

@keyframes floatCard{

    0%{
        transform:translateY(0px);
    }

    50%{
        transform:translateY(-8px);
    }

    100%{
        transform:translateY(0px);
    }

}

/* RESPONSIVE */

@media(max-width:992px){
    .site-header{
        padding:16px 4%;
    }

    .site-nav{
        gap:16px;
    }

    section{
        padding:70px 6%;
    }

    .hero-content{
        padding:40px 30px;
    }

    .hero h1{
        font-size:62px;
    }
}

@media(max-width:768px){
    body{
        padding-top:72px;
    }

    .site-header{
        flex-direction:row;
        align-items:center;
        gap:10px;
    }

    .hamburger{
        display:flex;
    }

    .site-nav{
        position:absolute;
        top:100%;
        left:0;
        width:100%;
        flex-direction:column;
        background:rgba(12,12,12,0.98);
        backdrop-filter:blur(16px);
        padding:20px;
        border-top:1px solid rgba(255,255,255,0.1);
        display:none;
        gap:0;
    }

    .site-nav a{
        padding:12px 0;
        border-bottom:1px solid rgba(255,255,255,0.05);
    }

    .site-nav a:last-child{
        border-bottom:none;
    }

    .hero{
        min-height:calc(100vh - 72px);
        padding:16px;
    }

    .hero-content{
        width:100%;
        padding:30px 24px;
        border-radius:28px;
    }

    .hero h1{
        font-size:48px;
    }

    .hero p{
        font-size:17px;
        max-width:100%;
    }

    .hero-buttons{
        gap:12px;
    }

    .btn{
        width:100%;
        min-width:0;
        padding:16px 18px;
    }

    .section-title{
        font-size:30px;
    }

    .cards{
        gap:20px;
    }

    .card img{
        height:280px;
    }

    .gallery{
        gap:16px;
    }

    .gallery img{
