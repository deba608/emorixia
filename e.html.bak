<!-- IMAGE POPUP -->

<div id="imagePopup" class="image-popup">

<span onclick="closeImage()">&times;</span>

<div class="zoom-controls">

<button onclick="zoomIn()">+</button>

<button onclick="zoomOut()">−</button>

<button onclick="resetZoom()">Reset</button>

</div>

<img id="popupImg">

</div>

<script>

/* HAMBURGER MENU TOGGLE */

const hamburger = document.getElementById('hamburger');
const nav = document.querySelector('.site-nav');

hamburger.addEventListener('click', function(){
    hamburger.classList.toggle('active');
    nav.classList.toggle('mobile-active');
});

// Close menu when a link is clicked
document.querySelectorAll('.site-nav a').forEach(link => {
    link.addEventListener('click', function(){
        hamburger.classList.remove('active');
        nav.classList.remove('mobile-active');
    });
});

/* CONTACT FORM */

const contactForm = document.getElementById('contactForm');
const formMessage = document.getElementById('formMessage');

contactForm.addEventListener('submit', async function(e){
    e.preventDefault();
    
    const name = document.getElementById('name').value;
    const email = document.getElementById('email').value;
    const phone = document.getElementById('phone').value;
    const service = document.getElementById('service').value;
    const message = document.getElementById('message').value;
    
    // Prepare email data
    const emailData = {
        name: name,
        email: email,
        phone: phone,
        service: service,
        message: message
    };
    
    try {
        // Using Formspree service (update with your Formspree form ID)
        // First, replace 'YOUR_FORMSPREE_ID' with your actual Formspree form ID
        const response = await fetch('https://formspree.io/f/YOUR_FORMSPREE_ID', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify(emailData)
        });
        
        if (response.ok) {
            formMessage.classList.add('success');
            formMessage.classList.remove('error');
            formMessage.textContent = '✅ Message sent successfully! We\'ll get back to you soon.';
            contactForm.reset();
        } else {
            throw new Error('Form submission failed');
        }
    } catch (error) {
        formMessage.classList.add('error');
        formMessage.classList.remove('success');
        formMessage.textContent = '❌ Error sending message. Please try WhatsApp instead.';
        console.error('Error:', error);
    }
});

/* FAQ ACCORDION */

const faqItems = document.querySelectorAll('.faq-item');

faqItems.forEach(item => {
    const question = item.querySelector('.faq-question');
    
    question.addEventListener('click', function(){
        // Close other open FAQs
        faqItems.forEach(otherItem => {
            if(otherItem !== item){
                otherItem.classList.remove('active');
            }
        });
        
        // Toggle current FAQ
        item.classList.toggle('active');
    });
});

/* NEWSLETTER SIGNUP */

const newsletterForm = document.getElementById('newsletterForm');
const newsletterMessage = document.getElementById('newsletterMessage');

newsletterForm.addEventListener('submit', async function(e){
    e.preventDefault();
    
    const email = document.getElementById('newsletterEmail').value;
    
    try {
        // Using Formspree or your email service
        // Replace 'YOUR_NEWSLETTER_FORM_ID' with your actual form ID
        const response = await fetch('https://formspree.io/f/YOUR_NEWSLETTER_FORM_ID', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify({
                email: email,
                type: 'newsletter'
            })
        });
        
        if (response.ok) {
            newsletterMessage.classList.add('show');
            newsletterMessage.style.color = '#fff';
            newsletterMessage.textContent = '✅ Thanks for subscribing! Check your email.';
            newsletterForm.reset();
            
            setTimeout(() => {
                newsletterMessage.classList.remove('show');
            }, 3000);
        } else {
            throw new Error('Subscription failed');
        }
    } catch (error) {
        newsletterMessage.classList.add('show');
        newsletterMessage.style.color = '#ff9999';
        newsletterMessage.textContent = '❌ Error subscribing. Try again!';
        console.error('Error:', error);
    }
});

/* IMAGE POPUP */

let images = document.querySelectorAll(".card img, .gallery img");

let popup = document.getElementById("imagePopup");
let popupImg = document.getElementById("popupImg");

let scale = 1;
let posX = 0;
let posY = 0;

let isDragging = false;

let startX;
let startY;

/* OPEN IMAGE */

images.forEach(function(img){

    img.addEventListener("click", function(){

        popup.style.display = "flex";

        popupImg.src = this.src;

        scale = 1;
        posX = 0;
        posY = 0;

        updateTransform();

    });

});

/* CLOSE */

function closeImage(){

    popup.style.display = "none";

}

/* UPDATE TRANSFORM */

function updateTransform(){

    popupImg.style.transform =
    `translate(${posX}px, ${posY}px) scale(${scale})`;

}

/* ZOOM IN */

function zoomIn(){

    scale += 0.2;

    updateTransform();

}

/* ZOOM OUT */

function zoomOut(){

    if(scale > 0.4){

        scale -= 0.2;

        updateTransform();

    }

}

/* RESET */

function resetZoom(){

    scale = 1;
    posX = 0;
    posY = 0;

    updateTransform();

}

/* SCROLL ZOOM */

popupImg.addEventListener("wheel", function(e){

    e.preventDefault();

    if(e.deltaY < 0){

        scale += 0.1;

    }else{

        scale -= 0.1;

    }

    if(scale < 0.4){

        scale = 0.4;

    }

    updateTransform();

});

/* DRAG IMAGE */

popupImg.addEventListener("mousedown", function(e){

    isDragging = true;

    startX = e.clientX - posX;
    startY = e.clientY - posY;

    popupImg.style.cursor = "grabbing";

});

document.addEventListener("mousemove", function(e){

    if(!isDragging) return;

    posX = e.clientX - startX;
    posY = e.clientY - startY;

    updateTransform();

});

document.addEventListener("mouseup", function(){

    isDragging = false;

    popupImg.style.cursor = "grab";

});

</script>

</body>
</html>